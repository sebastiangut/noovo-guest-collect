# ─── Convex ───────────────────────────────────────────────────────────
# Găsești această valoare după ce rulezi: npx convex dev
# Dashboard Convex → Settings → URL & Deploy Key
VITE_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# ─── Twilio (se setează în Convex Dashboard → Environment Variables) ──
# Nu le adăuga în acest fișier .env — Convex le citește din propriul dashboard
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE=+40XXXXXXXXX
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── App Config ───────────────────────────────────────────────────────
# PIN pentru accesul la dashboard (schimbă-l!)
VITE_DASHBOARD_PIN=1234
